{
  "name": "@hivemind/broker",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "files": ["dist"],
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');fs.mkdirSync('dist/prompts',{recursive:true});fs.readdirSync('src/prompts').filter(f=>f.endsWith('.md')).forEach(f=>fs.copyFileSync('src/prompts/'+f,'dist/prompts/'+f))\"",
    "start": "node dist/index.js",
    "test": "node --test dist/tests/**/*.test.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "latest",
    "uuid": "^9.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/uuid": "^9.0.0",
    "typescript": "^5.4.0"
  }
}
